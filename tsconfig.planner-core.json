{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "src/lib/planner/catalog/**/*.ts",
    "src/lib/planner/simulator/**/*.ts",
    "src/lib/planner/snapshot-to-simulation-state.ts"
  ]
}
